# CloakBrowser MCP 配置示例
# 复制为 .env 后按需修改；也可以在 MCP Host env 中逐项设置。

# MCP transport: stdio | sse | streamable-http
CLOAKBROWSER_MCP_TRANSPORT=stdio
CLOAKBROWSER_MCP_HOST=127.0.0.1
CLOAKBROWSER_MCP_PORT=8000
CLOAKBROWSER_MCP_PATH=/mcp
CLOAKBROWSER_MCP_STATELESS_HTTP=true
CLOAKBROWSER_MCP_JSON_RESPONSE=true

# 默认浏览器启动模式: browser | context | persistent
CLOAKBROWSER_MCP_LAUNCH_MODE=context
CLOAKBROWSER_MCP_HEADLESS=true
CLOAKBROWSER_MCP_STEALTH_ARGS=true
CLOAKBROWSER_MCP_BACKEND=playwright

# 代理与地理信号
# 支持 http://user:pass@host:port、socks5://user:pass@host:port 或 JSON proxy dict。
CLOAKBROWSER_MCP_PROXY=
CLOAKBROWSER_MCP_GEOIP=false
CLOAKBROWSER_MCP_TIMEZONE=
CLOAKBROWSER_MCP_LOCALE=
CLOAKBROWSER_MCP_GEOLOCATION=

# fingerprint 配置
CLOAKBROWSER_MCP_FINGERPRINT_SEED=
CLOAKBROWSER_MCP_FINGERPRINT_PLATFORM=
CLOAKBROWSER_MCP_FINGERPRINT_ARGS={}
CLOAKBROWSER_MCP_EXTRA_ARGS=[]

# humanize 行为层
CLOAKBROWSER_MCP_HUMANIZE=false
CLOAKBROWSER_MCP_HUMAN_PRESET=default
CLOAKBROWSER_MCP_HUMAN_CONFIG=

# profile / persistent session
CLOAKBROWSER_MCP_PROFILE_ROOT=.cloakbrowser-mcp/profiles
CLOAKBROWSER_MCP_PROFILE_NAME=default
CLOAKBROWSER_MCP_USER_DATA_DIR=
CLOAKBROWSER_MCP_PERSISTENT_SESSION=false
# 启动时恢复登录态：storage_state JSON 文件路径或 JSON 对象（仅 browser/context 模式）
CLOAKBROWSER_MCP_STORAGE_STATE=

# 扩展、viewport、context / launch kwargs
CLOAKBROWSER_MCP_EXTENSION_PATHS=[]
CLOAKBROWSER_MCP_USER_AGENT=
CLOAKBROWSER_MCP_VIEWPORT=
CLOAKBROWSER_MCP_NO_VIEWPORT=false
CLOAKBROWSER_MCP_COLOR_SCHEME=
CLOAKBROWSER_MCP_CONTEXT_KWARGS={}
CLOAKBROWSER_MCP_LAUNCH_KWARGS={}

# CDP
CLOAKBROWSER_MCP_CDP_HOST=127.0.0.1
CLOAKBROWSER_MCP_CDP_PORT=
CLOAKBROWSER_MCP_CDP_EXPOSE_HOST=127.0.0.1
CLOAKBROWSER_MCP_CDP_TIMEOUT_SECONDS=10

# 运行时、日志、自检
CLOAKBROWSER_MCP_TIMEOUT_MS=30000
CLOAKBROWSER_MCP_RETRIES=0
# 并发会话上限（0 = 不限制）和空闲会话自动回收秒数（0 = 不回收）
CLOAKBROWSER_MCP_MAX_SESSIONS=0
CLOAKBROWSER_MCP_SESSION_IDLE_TIMEOUT_SECONDS=0
# get_text/get_html 默认截断长度（0 = 不截断），保护 Agent 上下文
CLOAKBROWSER_MCP_MAX_OUTPUT_CHARS=20000
CLOAKBROWSER_MCP_INSTALL_BROWSER_ON_START=false
CLOAKBROWSER_MCP_HEALTHCHECK_PROBE_BROWSER=false
CLOAKBROWSER_MCP_CHECK_DOCKER=false
CLOAKBROWSER_MCP_CHECK_NODE=true
CLOAKBROWSER_MCP_LOG_LEVEL=INFO
CLOAKBROWSER_MCP_LOG_FILE=

# CloakBrowser 上游变量
CLOAKBROWSER_BINARY_PATH=
CLOAKBROWSER_CACHE_DIR=
CLOAKBROWSER_DOWNLOAD_URL=
CLOAKBROWSER_AUTO_UPDATE=true
CLOAKBROWSER_SKIP_CHECKSUM=false
CLOAKBROWSER_GEOIP_TIMEOUT_SECONDS=5
